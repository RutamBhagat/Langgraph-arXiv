# LangChain Agent Environment Variables
# Copy this file to .env and fill in your API keys

# ============================================
# Model Provider API Key (required)
# ============================================

# OpenAI API key (optional when using local OAuth/OpenAI-compatible proxy)
# Leave empty when your proxy does not require a key.
# OPENAI_API_KEY=

# OpenAI-compatible proxy base URL (required for this server setup)
# Example from codex/openai-oauth local proxy: http://127.0.0.1:10531/v1
# OPENAI_PROXY_BASE_URL=http://127.0.0.1:10531/v1

# ============================================
# Optional: LangSmith for Tracing & Debugging
# ============================================

# Enable LangSmith tracing (recommended for development)
# Sign up at: https://smith.langchain.com/
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=langchain-agent-starter

# ============================================
# Optional: Additional Tool API Keys
# ============================================

# Tavily API Key (for web search tool)
# Get your key at: https://app.tavily.com/
# TAVILY_API_KEY=your-tavily-api-key-here

CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/skyclad_langgraph
