{
  "name": "skyclad_langgraph",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:server": "turbo -F server dev",
    "eval": "turbo -F server eval",
    "db:push": "turbo -F @skyclad_langgraph/db db:push",
    "db:studio": "turbo -F @skyclad_langgraph/db db:studio",
    "db:generate": "turbo -F @skyclad_langgraph/db db:generate",
    "db:migrate": "turbo -F @skyclad_langgraph/db db:migrate",
    "db:start": "turbo -F @skyclad_langgraph/db db:start",
    "db:watch": "turbo -F @skyclad_langgraph/db db:watch",
    "db:stop": "turbo -F @skyclad_langgraph/db db:stop",
    "db:down": "turbo -F @skyclad_langgraph/db db:down"
  },
  "dependencies": {
    "@skyclad_langgraph/env": "workspace:*",
    "dotenv": "^17.2.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@skyclad_langgraph/config": "workspace:*",
    "@types/node": "^22.0.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
